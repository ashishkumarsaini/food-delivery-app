{
  "expo": {
    "name": "food-delivery",
    "slug": "food-delivery",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fooddelivery",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fooddelivery"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.fooddelivery"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/fraunces/400Regular.ttf",
            "node_modules/@expo-google-fonts/fraunces/500Medium.ttf",
            "node_modules/@expo-google-fonts/fraunces/600SemiBold.ttf",
            "node_modules/@expo-google-fonts/fraunces/700Bold.ttf"
          ]
        }
      ]
    ]
  }
}